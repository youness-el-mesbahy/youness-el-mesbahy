---
import { MoveRight } from '@lucide/astro'
import { twMerge } from 'tailwind-merge'
import Badge from './Badge.astro'

const { project, className } = Astro.props
const { title, imageUrl, description, technologies } = project.data;
---

<div class={twMerge('relative max-w-[21.35vw py-4 px-5 rounded-lg border border-gray-200 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg hover:border-primary', className)}>
    <div class="w-full flex justify-center  h-[162]">
    <img
      src={imageUrl}
      alt={title}
      width={400}
      height={225}
      class="w-full mx-h-[10.55vw aspect-video rounded-lg object-cover bg-gray-100"
      loading="lazy"
    />
    </div>
    <h3 class="text-lg mt-4">{title}</h3>
    <p class="text-sm mt-[0.375rem] font-light">
        {description}
    </p>
    <div class="mt-3 space-x-2 space-y-2">
        {technologies.map(technology => (
                <Badge size="small">
                    <img src={technology.icon} width="14" height="14" class="inline-block" />
                    <span>{technology.name}</span>
                </Badge>
        ))}
    </div>
    <div class="mt-2 invisible ">
        place
    </div>
    <div class=" absolute bottom-3 left-1/2 -translate-x-1/2">
        <MoveRight />
    </div>
</div>

<script>
</script>
