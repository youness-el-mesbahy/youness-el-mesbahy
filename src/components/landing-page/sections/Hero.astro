---
import { Copy, Github, Instagram, Linkedin, MoveRight } from '@lucide/astro'

import ContactModal from '../../ContactModal'
import Button from '../../ui/Button.astro'
---

<section class="pb-24 max-[696px]:pb-16">
  <div
    class="container-xl mx-auto mt-[25vh] flex items-center justify-center gap-32 max-[1116px]:mt-36 max-[696px]:mt-32"
  >
    <div>
      <!--<div>-->

      <!--    <h1 class="text-4xl mb-3 font-semibold">-->
      <!--        Building Scalable, Performant Full-Stack Applications-->
      <!--    </h1>-->
      <!--    <p class="text-base">-->
      <!--        I architect and deliver clean, maintainable code for-->
      <!--        fast-growing businesses.-->
      <!--    </p>-->
      <!--</div>-->
      <div>
        <div
          class="flex items-center justify-between max-[1116px]:flex-col max-[1116px]:items-start max-[1116px]:gap-6"
        >
          <h2
            class="text-8xl font-semibold text-nowrap max-[1116px]:text-6xl max-[952px]:text-wrap"
          >
            Full-stack <span class="hidden max-[1116px]:inline-block">Developer</span>
          </h2>
          <div
            class="grid w-80 grid-cols-[2fr_auto] justify-between justify-items-center max-[1116px]:w-full max-[1116px]:grid-cols-1 max-[1116px]:justify-items-start max-[1116px]:gap-4"
          >
            <p class="font-base grow font-semibold">
              2+ years of experience building modern React applications with strong backend
              foundations.
            </p>
            <div class="rotate-90 max-[1116px]:row-start-1 max-[1116px]:rotate-0">
              <a href="#projects">
                <Button
                  className="bg-carbon-1200 dark:bg-carbon-1800 dark:text-carbon-400 rounded-full tracking-wide"
                >
                  Projects &nbsp;
                  <MoveRight size="1.25rem" />
                </Button>
              </a>
            </div>
          </div>
        </div>
        <div
          class="mt-12 flex items-end justify-between gap-16 max-[1116px]:mt-6 max-[514px]:gap-0"
        >
          <div
            class="max-[514px]: flex grow items-center justify-center gap-6 max-[514px]:flex-col"
          >
            <div
              class="mb-3 flex items-center gap-4 max-[627px]:mb-0 max-[330px]:w-full max-[330px]:flex-col max-[330px]:justify-center"
            >
              <ContactModal client:only="react" />
              <Button
                id="copy-email-hero"
                variant="secondary"
                aria-label="Copy email"
                className="max-[330px]:w-full text-nowrap"
              >
                <span id="copy-icon-hero"><Copy size="1.25rem" /></span>
                <span id="copy-text-hero">&nbsp;Copy Email</span>
              </Button>
              <span id="copy-live-hero" class="sr-only" aria-live="polite" role="status"></span>
            </div>
            <div class="hidden items-center gap-4 max-[627px]:flex">
              <a href="https://github.com/youness-el-mesbahy" target="_blank" rel="noreferrer" aria-label="GitHub">
                <Github size="20" class="hover:text-primary duration-300" />
              </a>
              <a
                href="https://www.linkedin.com/in/youness-el-mesbahy-7327992b8"
                target="_blank"
                rel="noreferrer"
                aria-label="LinkedIn"
              >
                <Linkedin size="20" class="hover:text-primary duration-300" />
              </a>
              <a
                href="https://www.instagram.com/youness.el.mesbahy/"
                target="_blank"
                rel="noreferrer"
                aria-label="Instagram"
              >
                <Instagram size="20" class="hover:text-primary duration-300" />
              </a>
            </div>
          </div>
          <h2 class="text-8xl font-semibold text-nowrap max-[1116px]:hidden">Developer</h2>
        </div>
      </div>
    </div>
    <!--<div class="relative">-->
    <!--    <div class="h-[22.5rem] w-[22.5rem] overflow-hidden flex items-center justify-center bg-carbon-700 rounded-lg">-->
    <!--        <Image src={HeroImage}  alt="HeroImage" />-->
    <!--    </div>-->
    <!--    <div-->
    <!--        class="h-[22.5rem] w-[22.5rem] absolute rounded-lg z-[-1] border-primary border-2 top-0 left-0 translate-x-6 translate-y-6"-->
    <!--    >-->
    <!--    </div>-->
    <!--</div>-->
  </div>
</section>

<script>
const copyBtn = document.getElementById('copy-email-hero')
const copyLive = document.getElementById('copy-live-hero')

const originalHtml = copyBtn?.innerHTML

copyBtn?.addEventListener('click', async () => {
  try {
    await navigator.clipboard.writeText('younessmesbahy@gmail.com')
    copyBtn.innerHTML
      = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check"><path d="M20 6 9 17l-5-5"/></svg>&nbsp;Copied!'
    if (copyLive)
      copyLive.textContent = 'Email copied to clipboard'
    setTimeout(() => {
      copyBtn.innerHTML = originalHtml
    }, 2000)
  }
  catch {
    if (copyLive)
      copyLive.textContent = 'Failed to copy email'
  }
})
</script>
